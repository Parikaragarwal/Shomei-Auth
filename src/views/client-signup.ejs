<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Client Signup</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>

<div class="container">
    <h1>Client Signup</h1>

    <form action="/client-signup" method="POST">

        <input
            type="text"
            name="name"
            placeholder="Client Name"
            required
        >

        <input
            type="text"
            name="base_url"
            placeholder="Base URL"
            required
        >

        <input
            type="text"
            name="redirect_uri"
            placeholder="Redirect URI"
            required
        >

        <button type="submit">
            Register Client
        </button>

    </form>
</div>

</body>
</html>