<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Client Registered</title>

    <link
        rel="stylesheet"
        href="/client-created.css"
    >
</head>

<body>

<div class="container">

    <h1>Client Registered Successfully</h1>

    <div class="warning">
        Save your client secret now.
        It will not be shown again.
    </div>

    <div class="card">

        <h2>Client Credentials</h2>

        <div class="field">
            <span class="label">Client ID</span>

            <code><%= client_id %></code>
        </div>

        <div class="field">
            <span class="label">Client Secret</span>

            <code><%= client_secret %></code>
        </div>

    </div>

    <div class="card">

        <h2>Authorization Flow</h2>

        <ol>
            <li>
                Redirect user to:
            </li>
        </ol>

        <code>
            http://localhost:3371/authorize/<%= client_id %>
        </code>

        <ol start="2">
            <li>
                User logs in and authorizes your app.
            </li>

            <li>
                Your redirect URI receives:
            </li>
        </ol>

        <code>
            ?shortcode=YOUR_SHORTCODE
        </code>

        <ol start="4">
            <li>
                Exchange shortcode for access token.
            </li>

            <li>
                Use access token to fetch user info.
            </li>
        </ol>

    </div>

    <div class="card">

        <h2>Token Exchange Example</h2>

<pre>
curl -X POST http://localhost:3371/token-exchange \
-H "Content-Type: application/json" \
-d '{
  "shortcode":"YOUR_SHORTCODE",
  "clientId":"<%= client_id %>",
  "clientSecret":"<%= client_secret %>"
}'
</pre>

    </div>

    <div class="card">

        <h2>User Info Example</h2>

<pre>
curl http://localhost:3371/userinfo \
-H "Authorization: Bearer YOUR_ACCESS_TOKEN"
</pre>

    </div>

</div>

</body>
</html>