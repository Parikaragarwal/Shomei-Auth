<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Authorize Client</title>

    <link
        rel="stylesheet"
        href="/styles.css"
    >
</head>

<body>

<div class="container">

    <h1>Authorize Application</h1>

    <p>
        <strong><%= client.name %></strong>
        wants access to your account.
    </p>

    <p>
        Redirect URI:
    </p>

    <code>
        <%= client.redirect_uri %>
    </code>

    <form
        action="/authorize/confirm"
        method="POST"
    >

        <input
            type="hidden"
            name="client_id"
            value="<%= client.client_id %>"
        >

        <button type="submit">
            Allow Access
        </button>

    </form>

    <form
        action="/authorize/deny"
        method="POST"
        style="margin-top: 1rem;"
    >

        <input
            type="hidden"
            name="client_id"
            value="<%= client.client_id %>"
        >

        <button
            type="submit"
            style="background:#991b1b;"
        >
            Deny
        </button>

    </form>

</div>

</body>
</html>